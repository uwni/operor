{
  "instruments": {
    "d1": {
      "adapter": "psu.json",
      "resource": "USB0::1::INSTR"
    }
  },
  "pipeline": {
    "record": {"all": "all"}
  },
  "tasks": [
    {
      "while": {"string": "true"},
      "steps": [
        {
          "call": {
            "call": "d1.set",
            "args": {
              "voltage": {"scalar": {"string": "5"}}
            }
          }
        }
      ]
    }
  ],
  "stop_when": {"string": "$ELAPSED_MS >= 2000 || $ITER >= 3"}
}
