{
  "instruments": {
    "d1": {
      "driver": "psu",
      "resource": "USB0::1::INSTR"
    }
  },
  "tasks": [
    {
      "every_ms": 0,
      "steps": [
        {
          "call": "set_voltage",
          "instrument": "d1",
          "args": {
            "voltage": 5,
            "channels": [1, 2]
          }
        }
      ]
    }
  ]
}