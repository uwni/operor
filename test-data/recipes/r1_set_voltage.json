{
  "instruments": {
    "d1": {
      "adapter": "psu.json",
      "resource": "USB0::1::INSTR"
    }
  },
  "pipeline": {
    "record": {"all": "all"}
  },
  "tasks": [
    {
      "steps": [
        {
          "call": {
            "call": "d1.set_voltage",
            "args": {
              "voltage": {"scalar": {"int": 5}},
              "channels": {"list": [{"int": 1}, {"int": 2}]}
            }
          }
        }
      ]
    }
  ]
}
